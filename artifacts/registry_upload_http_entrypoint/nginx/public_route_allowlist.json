      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/plan",
      "methods": ["GET"]
    },
    {
      "name": "sheet_vitrina_refresh",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/refresh",
      "methods": ["POST"]
    },
    {
      "name": "sheet_vitrina_status",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/status",
      "methods": ["GET"]
    },
    {
      "name": "sheet_vitrina_daily_report",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/daily-report",
      "methods": ["GET"]
    },
    {
      "name": "sheet_vitrina_stock_report",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/stock-report",
      "methods": ["GET"]
    },
    {
