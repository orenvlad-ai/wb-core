      "name": "registry_upload_bundle",
      "match": "exact",
      "path": "/v1/registry-upload/bundle",
      "methods": ["POST"]
    },
    {
      "name": "cost_price_upload",
      "match": "exact",
      "path": "/v1/cost-price/upload",
      "methods": ["POST"]
    },
    {
