      "path": "/v1/sheet-vitrina-v1/load",
      "methods": ["POST"]
    },
    {
      "name": "sheet_vitrina_job",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/job",
      "methods": ["GET"]
    },
    {
      "name": "sheet_vitrina_seller_session_check",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/seller-portal-session/check",
      "methods": ["GET"]
    },
    {
      "name": "sheet_vitrina_seller_recovery_status",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/seller-portal-recovery/status",
