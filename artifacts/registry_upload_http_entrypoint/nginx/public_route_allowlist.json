    },
    {
      "name": "sheet_vitrina_seller_recovery_stop",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/seller-portal-recovery/stop",
      "methods": ["POST"]
    },
    {
      "name": "sheet_vitrina_seller_recovery_launcher",
      "match": "exact",
      "path": "/v1/sheet-vitrina-v1/seller-portal-recovery/launcher.zip",
      "methods": ["GET"]
    },
    {
      "name": "sheet_vitrina_supply_factory_order",
      "match": "prefix",
      "path": "/v1/sheet-vitrina-v1/supply/factory-order/",
      "methods": ["GET", "POST", "DELETE"]
    },
    {
      "name": "sheet_vitrina_supply_wb_regional",
      "match": "prefix",
      "path": "/v1/sheet-vitrina-v1/supply/wb-regional/",
      "methods": ["GET", "POST"]
    },
    {
      "name": "sheet_vitrina_operator_page",
      "match": "exact",
      "path": "/sheet-vitrina-v1/operator",
      "methods": ["GET"]
    }
  ]
}
